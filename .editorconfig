# OpenPerception EditorConfig
# https://editorconfig.org

root = true

# =============================================================================
# Default Settings
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# =============================================================================
# Python
# =============================================================================
[*.py]
indent_size = 4
max_line_length = 88

[*.pyi]
indent_size = 4

# =============================================================================
# C/C++
# =============================================================================
[*.{c,h,cpp,hpp,cc,hh}]
indent_size = 4

# =============================================================================
# JavaScript/TypeScript
# =============================================================================
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2

# =============================================================================
# Web
# =============================================================================
[*.{html,htm,xhtml}]
indent_size = 2

[*.{css,scss,less}]
indent_size = 2

[*.svg]
indent_size = 2

# =============================================================================
# Data/Config Files
# =============================================================================
[*.{json,jsonc}]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.toml]
indent_size = 4

[*.xml]
indent_size = 2

# =============================================================================
# Build/Config
# =============================================================================
[Makefile]
indent_style = tab
indent_size = 4

[*.mk]
indent_style = tab
indent_size = 4

[CMakeLists.txt]
indent_size = 2

[*.cmake]
indent_size = 2

# =============================================================================
# Shell Scripts
# =============================================================================
[*.{sh,bash,zsh}]
indent_size = 2

# =============================================================================
# Documentation
# =============================================================================
[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.rst]
indent_size = 3

[*.tex]
indent_size = 2

# =============================================================================
# Git
# =============================================================================
[.git*]
indent_size = 4
